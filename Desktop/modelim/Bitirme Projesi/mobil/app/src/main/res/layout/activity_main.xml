<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F0F"
    tools:context=".MainActivity">

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintHeight_percent="0.50"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomPanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Kamera üzerinde tahmin göstergesi -->
    <LinearLayout
        android:id="@+id/llPredictionOverlay"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#AA000000"
        android:padding="10dp"
        app:layout_constraintBottom_toTopOf="@id/bottomPanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvCurrentPrediction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔍 El gösterin..."
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvVoteStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="#1A1A2E"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        app:layout_constraintHeight_percent="0.50"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/previewView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- ÜÇ MOD BUTONU -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnLetter"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="Harf"
                android:textSize="13sp"
                android:textStyle="bold"
                android:backgroundTint="#00BCD4"
                android:textColor="#000000" />

            <Button
                android:id="@+id/btnWord"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:text="Kelime"
                android:textSize="13sp"
                android:textStyle="bold"
                android:backgroundTint="#555555"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnNumber"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="Sayı"
                android:textSize="13sp"
                android:textStyle="bold"
                android:backgroundTint="#555555"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <!-- ✅ Kaydırılabilir metin alanı + kontrol butonları -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <ScrollView
                android:id="@+id/svKelimeScroll"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:fillViewport="true">

                <TextView
                    android:id="@+id/tvOluşturulanKelime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:hint="El işareti yapın..."
                    android:textColorHint="#444466" />

            </ScrollView>

            <Button
                android:id="@+id/btnDeleteLastChar"
                android:layout_width="45dp"
                android:layout_height="40dp"
                android:text="⌫"
                android:padding="0dp"
                android:textSize="16sp"
                android:layout_marginEnd="6dp"
                android:backgroundTint="#FF9800"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnSaveWord"
                android:layout_width="55dp"
                android:layout_height="40dp"
                android:text="💾"
                android:padding="0dp"
                android:textSize="14sp"
                android:backgroundTint="#4CAF50"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="6dp">

            <Button
                android:id="@+id/btnExportCloudJson"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="☁️ Buluta Kaydet"
                android:textColor="#000000"
                android:backgroundTint="#00E676"
                android:textSize="16sp"
                android:textStyle="bold"
                android:padding="0dp" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333355"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KAYDEDİLEN METİNLER"
            android:textColor="#777799"
            android:textSize="10sp"
            android:textStyle="bold" />

        <ScrollView
            android:id="@+id/svSavedList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="2dp"
            android:background="#111122"
            android:padding="8dp">

            <TextView
                android:id="@+id/tvSavedRecords"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#E0E0E0"
                android:textSize="15sp"
                android:lineSpacingMultiplier="1.2" />
        </ScrollView>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>